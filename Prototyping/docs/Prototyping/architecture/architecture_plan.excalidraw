    {
      "id": "ugF2cHPed6ygXUn5yDgfo",
      "type": "text",
      "x": -229.0256662476096,
      "y": -184.2547056107113,
      "width": 443.7396240234375,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
