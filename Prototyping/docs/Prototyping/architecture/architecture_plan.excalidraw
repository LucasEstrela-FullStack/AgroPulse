      "versionNonce": 93674032,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779775714948,
      "link": null,
      "locked": false,
      "text": "Raster Processing = pipeline dessas matrizes:\nler raster\n\n↓\n\nrecortar área da fazenda\n\n↓\n\ncalcular NDVI\n\n↓\n\ngerar heatmap\n\n↓\n\nexportar resultado",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Raster Processing = pipeline dessas matrizes:\nler raster\n\n↓\n\nrecortar área da fazenda\n\n↓\n\ncalcular NDVI\n\n↓\n\ngerar heatmap\n\n↓\n\nexportar resultado",
